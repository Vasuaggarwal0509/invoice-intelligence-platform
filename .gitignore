# --- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments -------------------------------------------------
venv/
venv_*/            # venv_wsl, venv_linux, etc. when dev machines need multiple
.venv/
env/
.env

# --- Test / coverage / lint caches ---------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/
.tox/
dist/
*.egg-info/

# --- Pre-commit cache (per-user) -----------------------------------------
.pre-commit-cache/

# --- Local tool state -----------------------------------------------------
.claude/
.idea/
.vscode/

# --- Large regenerable dataset cache --------------------------------------
# 264 MB HuggingFace-cached dataset; re-downloaded by data_sources loaders.
# Kept at repo root (not under extraction_layer/) — HF embeds the full path
# into its lock filename and Windows MAX_PATH=260 overflows with extra depth.
data/katanaml/
# Pipeline run cache (rebuilt on first backend run).
data/cache/
# User-uploaded invoice blobs (business_layer.services.storage).
# Workspace-partitioned bytes — would leak real invoice content across users.
data/blobs/
# Spot-check render outputs (regenerable). Keep extraction_layer/evaluation/reports/ committed.
extraction_layer/evaluation/inspection/

# --- Local databases -----------------------------------------------------
# business_layer's default SQLite path lives under data/ and is real user
# state (sessions, hashes, invoices). Never commit. Blanket *.db catches
# any dev that overrides PLATFORM_DATABASE_URL to a different location.
*.db
*.sqlite
*.sqlite3
# SQLite auxiliary files (WAL mode creates these alongside the DB).
*.db-journal
*.db-wal
*.db-shm

# --- OS -------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Secrets --------------------------------------------------------------
*.pem
*.key
.env.local
.env.*.local
# OAuth client JSONs (Google, Microsoft, etc.) — the repo commits only
# *_dummy.json placeholders; real downloads stay local.
secrets/*
!secrets/*_dummy.json
!secrets/.gitkeep

# --- Logs ----------------------------------------------------------------
*.log
logs/
