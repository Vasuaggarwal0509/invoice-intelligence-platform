# PLATFORM_DATABASE_URL=sqlite:///data/business_layer.db
# PLATFORM_SESSION_COOKIE_SECURE=false     # false for local HTTP testing only
# PLATFORM_HSTS_ENABLED=false              # prod only
# PLATFORM_LOG_LEVEL=INFO
