# Copy this file to .env.local (git-ignored) and fill in the secrets.
#
# Generate a strong secret:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"

# --- REQUIRED -------------------------------------------------------------
PLATFORM_SECRET_KEY=

# --- Optional (defaults in business_layer/config/settings.py) ------------
